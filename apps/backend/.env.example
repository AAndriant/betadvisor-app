# =============================================================
# BetAdvisor Backend — Variables d'Environnement (EXEMPLE)
# =============================================================
# Copier ce fichier en .env et remplir les valeurs réelles.
# NE JAMAIS committer le fichier .env dans le dépôt.
# =============================================================

# --- Django ---
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de Données PostgreSQL ---
# Format: postgres://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgres://betadvisor:betadvisor@db:5432/betadvisor

# --- Docker DB (doit correspondre à DATABASE_URL) ---
POSTGRES_DB=betadvisor
POSTGRES_USER=betadvisor
POSTGRES_PASSWORD=betadvisor

# --- Google Gemini AI (OCR) ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Stripe TEST (développement local) ---
# Utiliser les clés sk_test_ / pk_test_ en local uniquement
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
STRIPE_SECRET_KEY=sk_test_your-secret-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# --- Stripe LIVE (production uniquement — via GitHub Secrets en CI) ---
# NE PAS remplir ces valeurs localement. Les stocker via :
#   gh secret set STRIPE_LIVE_SECRET_KEY --repo AAndriant/betadvisor-app
STRIPE_LIVE_SECRET_KEY=sk_live_REPLACE_VIA_GH_SECRET
STRIPE_LIVE_WEBHOOK_SECRET=whsec_REPLACE_VIA_GH_SECRET
STRIPE_PLATFORM_ACCOUNT_ID=acct_REPLACE_VIA_GH_SECRET

# --- Stripe Connect Platform ---
# CRITIQUE : toujours 20. Ne pas modifier sans code review.
# Le service utilise application_fee_percent=20 en constante explicite.
STRIPE_PLATFORM_FEE_PERCENT=20

# --- Subscription Price ID ---
STRIPE_SUBSCRIPTION_PRICE_ID=price_test_xxx

# --- Checkout Deep Links (Expo betadvisor://) ---
# Le jeton {CHECKOUT_SESSION_ID} est substitué par Stripe automatiquement
CHECKOUT_SUCCESS_URL=betadvisor://checkout/success?session_id={CHECKOUT_SESSION_ID}
CHECKOUT_CANCEL_URL=betadvisor://checkout/cancel
EXPO_APP_SCHEME=betadvisor

# --- Application ---
SITE_URL=http://localhost:8000
APP_BASE_URL=http://localhost:8000

# --- Sports API (Auto-Settlement) ---
# API-Sports.io key (covers Football, Basketball, Rugby, Volleyball, Handball,
# Hockey, Baseball, Formula 1, MMA) + API-Tennis.
# Sign up at https://api-sports.io — same key works for all sports.
API_SPORTS_KEY=your-api-sports-key-here

# --- Email (SMTP) ---
# Dev: console backend (no real emails sent)
# Prod: use django.core.mail.backends.smtp.EmailBackend + real SMTP
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@betadvisor.app
